import "sindarin-pkg-test/src/assert"
import "./assert/helpers"
import "sindarin-pkg-sdk/src/core/math"
import "../src/tensor"

# ===========================================================================
# test_init_orthogonal.sn — Phase 3 regression guard
#
# Direct unit test of Tensor.initOrthogonalSeeded. Verifies:
#
# Part A — Orthogonality math on a square matrix:
# Initialize a (d, d) tensor with gain=1.0; assert each row has L2
# norm 1.0 (within 1e-5) and every pair of distinct rows has dot
# product 0.0 (within 1e-5). This is the definition of an
# orthonormal basis, the property that makes orthogonal init useful
# for deep-net gradient flow.
#
# Part B — Rectangular (rows < cols) case:
# Initialize a (3, 16) tensor — the typical shape for a PPO policy
# head (numActions x hiddenDim). Assert that the 3 rows are each
# unit-norm and mutually orthogonal in the 16-dim embedding space.
#
# Part C — Gain scaling:
# Initialize a (4, 8) tensor with gain=0.01 (the Andrychowicz policy-
# head convention). Assert each row's L2 norm is 0.01 within 1e-6.
# Pair with gain=2.0 and assert the same.
#
# Part D — Determinism:
# Two tensors initialized with the same seed and gain produce bit-
# identical element values. Two tensors with different seeds do NOT.
#
# Part E — No NaN or Inf:
# The Box-Muller + Gram-Schmidt pipeline has log(u1) and division
# by norm steps that could produce NaN/Inf on degenerate inputs.
# Run a large (32, 32) init and confirm every element is finite.
#
# Part F — Rectangular (rows > cols) semi-orthogonal case:
# Initialize a (16, 3) tensor — the shape of a hidden GNN layer with
# hidden_dim=16 and input_dim=3. In this regime torch.nn.init.orthogonal_
# produces a matrix with orthonormal COLUMNS (Wᵀ W = gain² · I_cols),
# not orthonormal rows. Verify:
# F1: gain=1.0 → every column has L2 norm 1.0 and all distinct
# column pairs have dot product 0.
# F2: gain=2.0 → column norms scale to gain; pairwise col dots
# remain ~0 within the gain²-scaled tolerance.
# F3: Determinism: same seed on (16, 3) is bit-identical, different
# seeds differ measurably.
# F4: Finiteness on a larger (48, 16) rows>cols init — catches any
# NaN/Inf from the scratch-transpose path.
# ===========================================================================

fn l2NormRow(data: double[], rowIdx: int, cols: int): double =>
  var sum: double = 0.0
  for var c: int = 0; c < cols; c++ =>
    var v: double = data[rowIdx * cols + c]
    sum = sum + v * v
  return sqrt(sum)

fn dotRows(data: double[], rowA: int, rowB: int, cols: int): double =>
  var sum: double = 0.0
  for var c: int = 0; c < cols; c++ =>
    sum = sum + data[rowA * cols + c] * data[rowB * cols + c]
  return sum

fn l2NormCol(data: double[], colIdx: int, rows: int, cols: int): double =>
  var sum: double = 0.0
  for var r: int = 0; r < rows; r++ =>
    var v: double = data[r * cols + colIdx]
    sum = sum + v * v
  return sqrt(sum)

fn dotCols(data: double[], colA: int, colB: int, rows: int, cols: int): double =>
  var sum: double = 0.0
  for var r: int = 0; r < rows; r++ =>
    sum = sum + data[r * cols + colA] * data[r * cols + colB]
  return sum

fn main(): void =>
  println("=== test_init_orthogonal ===")

  # -------------------------------------------------------------------
  # Part A — Square matrix, gain=1.0
  # -------------------------------------------------------------------
  println("--- Part A: square (8x8) matrix with gain=1.0 ---")
  var tA: Tensor = Tensor.zeros(8, 8)
  tA.initOrthogonalSeeded(1.0, 42l)
  var dataA: double[] = tA.toDoubles()
  assertEqualInt(len(dataA), 64, "Part A: tensor has 8*8 = 64 elements")

  for var r: int = 0; r < 8; r++ =>
    var n: double = l2NormRow(dataA, r, 8)
    assertApproxDouble(n, 1.0, 0.00001, $"Part A: row {r} has L2 norm 1.0")

  for var i: int = 0; i < 8; i++ =>
    for var j: int = i + 1; j < 8; j++ =>
      var d: double = dotRows(dataA, i, j, 8)
      assertApproxDouble(d, 0.0, 0.00001, $"Part A: rows {i} and {j} are orthogonal")

  # -------------------------------------------------------------------
  # Part B — Rectangular rows < cols (policy head shape)
  # -------------------------------------------------------------------
  println("--- Part B: rectangular (3x16) policy-head shape ---")
  var tB: Tensor = Tensor.zeros(3, 16)
  tB.initOrthogonalSeeded(1.0, 7l)
  var dataB: double[] = tB.toDoubles()
  assertEqualInt(len(dataB), 48, "Part B: tensor has 3*16 = 48 elements")

  for var r: int = 0; r < 3; r++ =>
    var n: double = l2NormRow(dataB, r, 16)
    assertApproxDouble(n, 1.0, 0.00001, $"Part B: row {r} has L2 norm 1.0")

  for var i: int = 0; i < 3; i++ =>
    for var j: int = i + 1; j < 3; j++ =>
      var d: double = dotRows(dataB, i, j, 16)
      assertApproxDouble(d, 0.0, 0.00001, $"Part B: rows {i} and {j} are orthogonal in 16-dim space")

  # -------------------------------------------------------------------
  # Part C — Gain scaling
  # -------------------------------------------------------------------
  println("--- Part C: gain scaling ---")

  var tSmall: Tensor = Tensor.zeros(4, 8)
  tSmall.initOrthogonalSeeded(0.01, 99l)
  var dataSmall: double[] = tSmall.toDoubles()
  for var r: int = 0; r < 4; r++ =>
    var n: double = l2NormRow(dataSmall, r, 8)
    assertApproxDouble(n, 0.01, 0.000001, $"Part C: gain=0.01 row {r} has L2 norm 0.01")

  var tBig: Tensor = Tensor.zeros(4, 8)
  tBig.initOrthogonalSeeded(2.0, 99l)
  var dataBig: double[] = tBig.toDoubles()
  for var r: int = 0; r < 4; r++ =>
    var n: double = l2NormRow(dataBig, r, 8)
    assertApproxDouble(n, 2.0, 0.00001, $"Part C: gain=2.0 row {r} has L2 norm 2.0")

  # Orthogonality must hold for any gain.
  for var i: int = 0; i < 4; i++ =>
    for var j: int = i + 1; j < 4; j++ =>
      var d: double = dotRows(dataSmall, i, j, 8)
      # Dot product scales with gain^2, so the threshold scales too.
      # For gain=0.01, 0*0.0001 = 0, so the bound is still ~0.
      assertApproxDouble(d, 0.0, 0.000001, $"Part C: gain=0.01 rows {i},{j} orthogonal")

  # -------------------------------------------------------------------
  # Part D — Determinism
  # -------------------------------------------------------------------
  println("--- Part D: determinism (seed reproducibility) ---")
  var t1: Tensor = Tensor.zeros(4, 8)
  t1.initOrthogonalSeeded(1.0, 123l)
  var d1: double[] = t1.toDoubles()

  var t2: Tensor = Tensor.zeros(4, 8)
  t2.initOrthogonalSeeded(1.0, 123l)
  var d2: double[] = t2.toDoubles()

  var sameMaxDelta: double = 0.0
  for var i: int = 0; i < len(d1); i++ =>
    var delta: double = d1[i] - d2[i]
    if delta < 0.0 =>
      delta = -delta
    if delta > sameMaxDelta =>
      sameMaxDelta = delta
  assertApproxDouble(sameMaxDelta, 0.0, 0.00000001, "Part D: same seed produces bit-identical values")

  var t3: Tensor = Tensor.zeros(4, 8)
  t3.initOrthogonalSeeded(1.0, 456l)
  var d3: double[] = t3.toDoubles()

  var diffMaxDelta: double = 0.0
  for var i: int = 0; i < len(d1); i++ =>
    var delta: double = d1[i] - d3[i]
    if delta < 0.0 =>
      delta = -delta
    if delta > diffMaxDelta =>
      diffMaxDelta = delta
  assertTrue(diffMaxDelta > 0.01, "Part D: different seeds produce measurably different values")

  # -------------------------------------------------------------------
  # Part E — Finiteness on large matrix
  # -------------------------------------------------------------------
  println("--- Part E: no NaN or Inf on a 32x32 init ---")
  var tE: Tensor = Tensor.zeros(32, 32)
  tE.initOrthogonalSeeded(1.0, 31415l)
  var dataE: double[] = tE.toDoubles()
  var hasBad: bool = false
  for var i: int = 0; i < len(dataE); i++ =>
    var v: double = dataE[i]
    if v != v =>
      hasBad = true
  assertTrue(!hasBad, "Part E: no NaN in 32x32 orthogonal init")

  # Row norms still 1.0 on the larger matrix.
  for var r: int = 0; r < 32; r++ =>
    var n: double = l2NormRow(dataE, r, 32)
    assertApproxDouble(n, 1.0, 0.0001, $"Part E: row {r} has L2 norm 1.0 on 32x32")

  # -------------------------------------------------------------------
  # Part F — Rectangular rows > cols (semi-orthogonal, expansion layer)
  # -------------------------------------------------------------------
  println("--- Part F: rectangular (16x3) semi-orthogonal case ---")

  # F1: gain=1.0, columns orthonormal.
  var tF1: Tensor = Tensor.zeros(16, 3)
  tF1.initOrthogonalSeeded(1.0, 77l)
  var dataF1: double[] = tF1.toDoubles()
  assertEqualInt(len(dataF1), 48, "Part F1: tensor has 16*3 = 48 elements")

  for var c: int = 0; c < 3; c++ =>
    var n: double = l2NormCol(dataF1, c, 16, 3)
    assertApproxDouble(n, 1.0, 0.00001, $"Part F1: col {c} has L2 norm 1.0")

  for var i: int = 0; i < 3; i++ =>
    for var j: int = i + 1; j < 3; j++ =>
      var d: double = dotCols(dataF1, i, j, 16, 3)
      assertApproxDouble(d, 0.0, 0.00001, $"Part F1: cols {i},{j} are orthogonal in R^16")

  # F2: gain=2.0 scales column norms to 2.0.
  var tF2: Tensor = Tensor.zeros(16, 3)
  tF2.initOrthogonalSeeded(2.0, 77l)
  var dataF2: double[] = tF2.toDoubles()
  for var c: int = 0; c < 3; c++ =>
    var n: double = l2NormCol(dataF2, c, 16, 3)
    assertApproxDouble(n, 2.0, 0.00001, $"Part F2: gain=2.0 col {c} has L2 norm 2.0")
  # Dot products scale with gain^2 = 4, so widen tolerance accordingly.
  for var i: int = 0; i < 3; i++ =>
    for var j: int = i + 1; j < 3; j++ =>
      var d: double = dotCols(dataF2, i, j, 16, 3)
      assertApproxDouble(d, 0.0, 0.00004, $"Part F2: gain=2.0 cols {i},{j} orthogonal")

  # F3: determinism on rows > cols.
  var tF3a: Tensor = Tensor.zeros(16, 3)
  tF3a.initOrthogonalSeeded(1.0, 999l)
  var dF3a: double[] = tF3a.toDoubles()

  var tF3b: Tensor = Tensor.zeros(16, 3)
  tF3b.initOrthogonalSeeded(1.0, 999l)
  var dF3b: double[] = tF3b.toDoubles()

  var sameMaxDeltaF: double = 0.0
  for var i: int = 0; i < len(dF3a); i++ =>
    var delta: double = dF3a[i] - dF3b[i]
    if delta < 0.0 =>
      delta = -delta
    if delta > sameMaxDeltaF =>
      sameMaxDeltaF = delta
  assertApproxDouble(sameMaxDeltaF, 0.0, 0.00000001, "Part F3: same seed rows>cols bit-identical")

  var tF3c: Tensor = Tensor.zeros(16, 3)
  tF3c.initOrthogonalSeeded(1.0, 1000l)
  var dF3c: double[] = tF3c.toDoubles()

  var diffMaxDeltaF: double = 0.0
  for var i: int = 0; i < len(dF3a); i++ =>
    var delta: double = dF3a[i] - dF3c[i]
    if delta < 0.0 =>
      delta = -delta
    if delta > diffMaxDeltaF =>
      diffMaxDeltaF = delta
  assertTrue(diffMaxDeltaF > 0.01, "Part F3: different seeds rows>cols differ measurably")

  # F4: finiteness on a larger scratch-transpose init.
  var tF4: Tensor = Tensor.zeros(48, 16)
  tF4.initOrthogonalSeeded(1.0, 27182l)
  var dataF4: double[] = tF4.toDoubles()
  var hasBadF: bool = false
  for var i: int = 0; i < len(dataF4); i++ =>
    var v: double = dataF4[i]
    if v != v =>
      hasBadF = true
  assertTrue(!hasBadF, "Part F4: no NaN in 48x16 semi-orthogonal init")
  # Column norms still 1.0 on the larger matrix.
  for var c: int = 0; c < 16; c++ =>
    var n: double = l2NormCol(dataF4, c, 48, 16)
    assertApproxDouble(n, 1.0, 0.0001, $"Part F4: col {c} has L2 norm 1.0 on 48x16")

  summary()
  if failed() > 0 =>
    var crash: int = 1 / 0
