import "sindarin-pkg-test/src/assert"
import "./assert/helpers"
import "../src/tensor"
import "../src/gnn"

# ===========================================================================
# test_train_metric_callback.sn — Phase J / §4.2
#
# Verifies that:
# 1. A registered Sindarin lambda is invoked from C during
# Gnn.train() with (metric_name, value) pairs.
# 2. Per-epoch metrics (train_loss, grad_norm_l2) fire exactly once
# per epoch and the values match the corresponding entries in
# TrainResult.lossCurve / gradNormCurve to the limit of float
# roundtrip precision.
# 3. Scalar post-train metrics (weight_sum_in, weight_variance_in,
# input_mean, input_std, accuracy) fire exactly once per train
# and match the TrainResult fields.
# 4. Per-parameter metrics (param_norm_before/{i},
# param_norm_after/{i}, param_max_abs_delta/{i}) fire once each
# and match the TrainResult per-parameter arrays.
# 5. Clearing the callback stops further emissions — a second train
# call after clear() pushes nothing into the capture buffers.
#
# Crash-on-fail via `failed() > 0 ⇒ 1/0`.
# ===========================================================================

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

fn singleNode(features: double[]): GraphTensors =>
  return GraphTensors {
    nodeFeatures: Tensor.fromDoubles(features, 1, 3),
    edgeIndex: Tensor.fromDoubles({0.0, 0.0}, 2, 1),
    edgeWeight: Tensor.fromDoubles({1.0}, 1, 1),
    batchIndex: Tensor.fromDoubles({0.0}, 1, 1),
    numNodes: 1, numEdges: 1, featureDim: 3
  }

fn buildGraphs(): GraphTensors[] =>
  var samples: double[][] = {
    {0.9, 0.1, 0.1},
    {0.1, 0.9, 0.1},
    {0.1, 0.1, 0.9},
    {0.8, 0.2, 0.1},
    {0.2, 0.8, 0.1},
    {0.1, 0.2, 0.8}
  }
  var graphs: GraphTensors[] = {}
  for var i: int = 0; i < len(samples); i++ =>
    graphs.push(singleNode(samples[i]))
  return graphs

fn buildLabels(): double[] =>
  var labels: double[] = {}
  var classes: int[] = {0, 1, 2, 0, 1, 2}
  for var i: int = 0; i < len(classes); i++ =>
    for var a: int = 0; a < 3; a++ =>
      if a == classes[i] =>
        labels.push(1.0)
      else =>
        labels.push(0.0)
  return labels

fn buildWeights(n: int): double[] =>
  var w: double[] = {}
  for var i: int = 0; i < n; i++ =>
    w.push(1.0)
  return w

fn makeConfig(): GnnConfig =>
  return GnnConfig {
    inputDim: 3, hiddenDim: 8, numActions: 3,
    numLayers: 1, arch: "gat", dropoutRate: 0.0
  }

# Count entries in a str[] matching a target name.
fn countMatches(names: str[], target: str): int =>
  var c: int = 0
  for var i: int = 0; i < len(names); i++ =>
    if names[i] == target =>
      c = c + 1
  return c

# Collect values from valueBuf where the corresponding name matches.
fn valuesFor(names: str[], values: double[], target: str): double[] =>
  var out: double[] = {}
  for var i: int = 0; i < len(names); i++ =>
    if names[i] == target =>
      out.push(values[i])
  return out

# Flatten a StringField[] labels vector into a deterministic
# "key1=value1,key2=value2" string for equality comparison in the
# test. Empty labels → empty string.
fn flattenLabels(labels: StringField[]): str =>
  var s: str = ""
  for var i: int = 0; i < len(labels); i++ =>
    if i > 0 =>
      s = s + ","
    s = s + labels[i].key + "=" + labels[i].value
  return s

# Count entries where (nameBuf[i], labelBuf[i]) == (targetName, targetLabels).
fn countMatchesWithLabels(names: str[], labelStrs: str[],
  targetName: str, targetLabels: str): int =>
  var c: int = 0
  for var i: int = 0; i < len(names); i++ =>
    if names[i] == targetName && labelStrs[i] == targetLabels =>
      c = c + 1
  return c

# Return the first value whose (name, labels) matches, or -999.0
# sentinel if not found. The caller asserts countMatchesWithLabels
# before calling this so a hit is guaranteed.
fn findValueWithLabels(names: str[], labelStrs: str[], values: double[],
  targetName: str, targetLabels: str): double =>
  for var i: int = 0; i < len(names); i++ =>
    if names[i] == targetName && labelStrs[i] == targetLabels =>
      return values[i]
  return - 999.0

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

fn main(): void =>
  println("=== test_train_metric_callback — Phase J / §4.2 ===")
  println("")

  # Shared buffers the callback appends into. Sindarin closures
  # capture by reference, so the lambda below mutates these when the
  # C side fires it. labelStrBuf is a parallel array of flattened
  # label strings ("key1=val1,key2=val2" or "" for empty labels).
  var nameBuf: str[] = {}
  var valueBuf: double[] = {}
  var labelStrBuf: str[] = {}

  # Register the callback. Two-step: the Sindarin parser only accepts
  # multi-arg lambda literals when bound to a named variable with an
  # explicit function type, not inlined at a call site.
  var captureCb: fn(str, double, StringField[]): void = fn(mname: str, mvalue: double, mlabels: StringField[]): void =>
    nameBuf.push(mname)
    valueBuf.push(mvalue)
    var flat: str = flattenLabels(mlabels)
    labelStrBuf.push(flat)
  sn_graph_set_train_metric_callback(captureCb)

  # Train.
  var model: Gnn = Gnn.createWithSeed(makeConfig(), 42l)
  var graphs: GraphTensors[] = buildGraphs()
  var labels: double[] = buildLabels()
  var weights: double[] = buildWeights(len(graphs))
  var opt: Optimizer = Optimizer.adamw(0.01, 0.0)
  var epochs: int = 5
  var result: TrainResult = model.train(
    graphs, labels, weights, opt, epochs, 3, 0.0, 42l)
  var nParams: int = len(model.parameters())

  println($"  captured {len(nameBuf)} metric emissions across {epochs} epochs")
  println($"  nParams={nParams}")

  # --- Per-epoch assertions --------------------------------------------
  # Per-epoch metrics ship with a single {epoch, "E"} label.
  assertEqualInt(countMatches(nameBuf, "train_loss"), epochs,
    $"train_loss emitted exactly {epochs} times (any label)")
  assertEqualInt(countMatches(nameBuf, "grad_norm_l2"), epochs,
    $"grad_norm_l2 emitted exactly {epochs} times (any label)")

  for var e: int = 0; e < epochs; e++ =>
    var epochLabel: str = $"epoch={e}"
    assertEqualInt(countMatchesWithLabels(nameBuf, labelStrBuf, "train_loss", epochLabel), 1,
      $"train_loss for epoch={e} emitted exactly once")
    assertEqualInt(countMatchesWithLabels(nameBuf, labelStrBuf, "grad_norm_l2", epochLabel), 1,
      $"grad_norm_l2 for epoch={e} emitted exactly once")

    var lossValue: double = findValueWithLabels(nameBuf, labelStrBuf, valueBuf, "train_loss", epochLabel)
    assertApproxDouble(lossValue, result.lossCurve[e], 0.0000000001,
      $"train_loss for epoch={e} matches TrainResult.lossCurve[{e}]")
    var gradValue: double = findValueWithLabels(nameBuf, labelStrBuf, valueBuf, "grad_norm_l2", epochLabel)
    assertApproxDouble(gradValue, result.gradNormCurve[e], 0.0000000001,
      $"grad_norm_l2 for epoch={e} matches TrainResult.gradNormCurve[{e}]")

  # --- Scalar post-train assertions ------------------------------------
  # Scalar metrics ship with empty labels.
  var emptyLabel: str = ""
  assertEqualInt(countMatchesWithLabels(nameBuf, labelStrBuf, "weight_sum_in", emptyLabel), 1,
    "weight_sum_in emitted exactly once with empty labels")
  var wSumV: double = findValueWithLabels(nameBuf, labelStrBuf, valueBuf, "weight_sum_in", emptyLabel)
  assertApproxDouble(wSumV, result.weightSumIn, 0.0000000001,
    "weight_sum_in callback value matches TrainResult")

  assertEqualInt(countMatchesWithLabels(nameBuf, labelStrBuf, "weight_variance_in", emptyLabel), 1,
    "weight_variance_in emitted exactly once with empty labels")
  var wVarV: double = findValueWithLabels(nameBuf, labelStrBuf, valueBuf, "weight_variance_in", emptyLabel)
  assertApproxDouble(wVarV, result.weightVarianceIn, 0.0000000001,
    "weight_variance_in callback value matches TrainResult")

  assertEqualInt(countMatchesWithLabels(nameBuf, labelStrBuf, "input_mean", emptyLabel), 1,
    "input_mean emitted exactly once with empty labels")
  var iMeanV: double = findValueWithLabels(nameBuf, labelStrBuf, valueBuf, "input_mean", emptyLabel)
  assertApproxDouble(iMeanV, result.inputMean, 0.0000000001,
    "input_mean callback value matches TrainResult")

  assertEqualInt(countMatchesWithLabels(nameBuf, labelStrBuf, "input_std", emptyLabel), 1,
    "input_std emitted exactly once with empty labels")
  var iStdV: double = findValueWithLabels(nameBuf, labelStrBuf, valueBuf, "input_std", emptyLabel)
  assertApproxDouble(iStdV, result.inputStd, 0.0000000001,
    "input_std callback value matches TrainResult")

  assertEqualInt(countMatchesWithLabels(nameBuf, labelStrBuf, "accuracy", emptyLabel), 1,
    "accuracy emitted exactly once with empty labels")
  var accV: double = findValueWithLabels(nameBuf, labelStrBuf, valueBuf, "accuracy", emptyLabel)
  assertApproxDouble(accV, result.accuracy, 0.0000000001,
    "accuracy callback value matches TrainResult")

  # --- Per-parameter assertions ----------------------------------------
  # The test model has numLayers=1 with arch="gat", so params are:
  # i=0: layer=0, kind=weight
  # i=1: layer=0, kind=bias
  # i=2: layer=0, kind=attSrc
  # i=3: layer=0, kind=attDst
  # i=4: kind=classW1 (no layer label)
  # i=5: kind=classB1
  # i=6: kind=classW2
  # i=7: kind=classB2
  var expectedLabels: str[] = {
    "layer=0,kind=weight",
    "layer=0,kind=bias",
    "layer=0,kind=attSrc",
    "layer=0,kind=attDst",
    "kind=classW1",
    "kind=classB1",
    "kind=classW2",
    "kind=classB2"
  }

  assertEqualInt(nParams, len(expectedLabels),
    "expected label vector matches nParams for 1-layer gat config")

  for var i: int = 0; i < nParams; i++ =>
    var plabel: str = expectedLabels[i]

    assertEqualInt(countMatchesWithLabels(nameBuf, labelStrBuf, "param_norm_before", plabel), 1,
      $"param_norm_before[{plabel}] emitted exactly once")
    assertEqualInt(countMatchesWithLabels(nameBuf, labelStrBuf, "param_norm_after", plabel), 1,
      $"param_norm_after[{plabel}] emitted exactly once")
    assertEqualInt(countMatchesWithLabels(nameBuf, labelStrBuf, "param_max_abs_delta", plabel), 1,
      $"param_max_abs_delta[{plabel}] emitted exactly once")

    var vBefore: double = findValueWithLabels(nameBuf, labelStrBuf, valueBuf, "param_norm_before", plabel)
    var vAfter: double = findValueWithLabels(nameBuf, labelStrBuf, valueBuf, "param_norm_after", plabel)
    var vDelta: double = findValueWithLabels(nameBuf, labelStrBuf, valueBuf, "param_max_abs_delta", plabel)
    assertApproxDouble(vBefore, result.paramNormBefore[i], 0.0000000001,
      $"param_norm_before[{plabel}] matches TrainResult[{i}]")
    assertApproxDouble(vAfter, result.paramNormAfter[i], 0.0000000001,
      $"param_norm_after[{plabel}] matches TrainResult[{i}]")
    assertApproxDouble(vDelta, result.paramMaxAbsDelta[i], 0.0000000001,
      $"param_max_abs_delta[{plabel}] matches TrainResult[{i}]")

  # --- Clear the callback and retrain: no new emissions --------------
  var bufLenBefore: int = len(nameBuf)
  sn_graph_clear_train_metric_callback()

  var model2: Gnn = Gnn.createWithSeed(makeConfig(), 42l)
  var result2: TrainResult = model2.train(
    graphs, labels, weights, opt, 3, 3, 0.0, 42l)
  # result2 is used just to avoid dead-code warnings if any — we care
  # that no buffer growth occurred.
  println($"  after clear: bufLen={len(nameBuf)} (was {bufLenBefore}), result2.loss={result2.loss}")

  assertEqualInt(len(nameBuf), bufLenBefore,
    "no new emissions after clear_train_metric_callback")

  # --- Re-register a new callback, ensure emissions resume ------------
  var resumeNames: str[] = {}
  var resumeCb: fn(str, double, StringField[]): void = fn(name: str, value: double, labels: StringField[]): void =>
    resumeNames.push(name)
  sn_graph_set_train_metric_callback(resumeCb)

  var model3: Gnn = Gnn.createWithSeed(makeConfig(), 42l)
  var r3: TrainResult = model3.train(
    graphs, labels, weights, opt, 2, 3, 0.0, 42l)
  println($"  after re-register: resumeNames has {len(resumeNames)} entries, r3.loss={r3.loss}")

  assertEqualInt(countMatches(resumeNames, "train_loss"), 2,
    "re-registered callback received 2 train_loss emissions for 2-epoch run")

  # Clean up the registration to avoid leaking the closure between
  # tests if this test binary is run alongside others.
  sn_graph_clear_train_metric_callback()

  println("")
  summary()

  if failed() > 0 =>
    var zero: int = 0
    var _crash: int = 1 / zero
