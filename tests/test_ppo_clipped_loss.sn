import "sindarin-pkg-test/src/assert"
import "./assert/helpers"
import "../src/tensor"

# ===========================================================================
# test_ppo_clipped_loss.sn — direct-mode unit test for
# sn_tensor_ppo_clipped_loss
#
# Verifies the PPO-clipped surrogate loss op produces correct scalars for
# hand-computed inputs across all four branches of the clip:
#
# A > 0, r in (1-eps, 1+eps)    → neither branch clips  (case 1)
# A > 0, r > 1+eps              → upper clip wins        (case 2)
# A < 0, r < 1-eps              → lower clip wins        (case 3)
# A < 0, r > 1+eps              → unclipped pull-down    (case 4)
# mixed batch (A>0 and A<0)     → per-batch averaging    (case 5)
#
# Cases 2 and 3 assert the **boundedness** property that motivates PPO:
# the clipped surrogate stays finite when the ratio drifts into the
# clamp region regardless of how far. Case 4 asserts that the unclipped
# branch still flows gradient when the policy has moved the wrong way.
#
# All cases share logits = [2.0, 0.0] so softmax(logits) = [0.8808, 0.1192],
# log_softmax[0] = -0.126928. Actions are always class 0 (one-hot [1, 0]).
# We vary oldLogProb to land the ratio in each region.
#
# Reference derivations (eps = 0.2, so clip range is [0.8, 1.2]):
#
# --- Case 1: ratio = 1 exactly ---
# oldLogProb = -0.126928 (match current log_pi)
# log_ratio  = 0.0
# ratio      = e^0 = 1.0
# advantage  = +1.0
# surrogate1 = 1.0
# ratio is inside [0.8, 1.2], so ratio_clip = 1.0
# surrogate2 = 1.0
# min        = 1.0
# loss       = -1/1 * 1.0 = -1.0
#
# --- Case 2: ratio ≈ 2.394 > 1+eps, positive advantage ---
# oldLogProb = -1.0
# log_ratio  = -0.126928 - (-1.0) = 0.873072
# ratio      = e^0.873072 ≈ 2.39411
# advantage  = +1.0
# surrogate1 = 2.39411
# ratio_clip = clamp(2.39411, 0.8, 1.2) = 1.2
# surrogate2 = 1.2
# min(2.39411, 1.2) = 1.2     # clipped wins — bounded
# loss       = -1/1 * 1.2 = -1.2
#
# --- Case 3: ratio ≈ 0.324 < 1-eps, negative advantage ---
# oldLogProb = 1.0
# log_ratio  = -0.126928 - 1.0 = -1.126928
# ratio      = e^-1.126928 ≈ 0.32396
# advantage  = -1.0
# surrogate1 = 0.32396 * -1 = -0.32396
# ratio_clip = clamp(0.32396, 0.8, 1.2) = 0.8
# surrogate2 = 0.8 * -1 = -0.8
# min(-0.32396, -0.8) = -0.8   # clipped wins — gradient is zero, bounded
# loss       = -1/1 * -0.8 = 0.8
#
# --- Case 4: ratio ≈ 6.508 > 1+eps, negative advantage ---
# oldLogProb = -2.0
# log_ratio  = -0.126928 - (-2.0) = 1.873072
# ratio      = e^1.873072 ≈ 6.50843
# advantage  = -1.0
# surrogate1 = 6.50843 * -1 = -6.50843  (very negative)
# ratio_clip = 1.2
# surrogate2 = 1.2 * -1 = -1.2
# min(-6.50843, -1.2) = -6.50843   # unclipped wins — pulls ratio DOWN
# loss       = -1/1 * -6.50843 = 6.50843
#
# This is the recovery branch: gradient flows back through the unclipped
# surrogate to push the chosen-action probability down toward its
# pre-update level, since A < 0 means we want LESS of this action.
#
# --- Case 5: mixed batch [case 1, case 3] ---
# Sample 0: per_sample = +1.0   (A>0, unclipped)
# Sample 1: per_sample = -0.8   (A<0, lower-clipped)
# loss = -1/2 * (1.0 + (-0.8)) = -1/2 * 0.2 = -0.1
#
# ===========================================================================

# Shared constants derived from the softmax of [2.0, 0.0].
# log(e^2 / (e^2 + e^0)) = 2 - log(e^2 + 1)
# ≈ 2 - log(8.38905609893)
# ≈ 2 - 2.12692801104297
# ≈ -0.12692801104297
# Stored at float-precision accurate to ~1e-8 — plenty of headroom for
# the 1e-3 tolerance on the loss assertions below.
fn currentLogPiClass0(): double =>
  return - 0.12692801

# ---------------------------------------------------------------------------
# Case 1 — ratio = 1, A > 0, no clip
# ---------------------------------------------------------------------------
fn case1(): void =>
  print("case 1: ratio=1 exactly (A>0, no clip)\n")

  var logits: Tensor = Tensor.fromDoubles({2.0, 0.0}, 1, 2)
  var oldLogProbs: Tensor = Tensor.fromDoubles({currentLogPiClass0()}, 1, 1)
  var actionsOneHot: Tensor = Tensor.fromDoubles({1.0, 0.0}, 1, 2)
  var advantages: Tensor = Tensor.fromDoubles({1.0}, 1, 1)

  var loss: Tensor = sn_tensor_ppo_clipped_loss(
    logits, oldLogProbs, actionsOneHot, advantages, 0.2, 0.0)
  var lossData: double[] = loss.toDoubles()

  assertEqualInt(len(lossData), 1, "case1 loss is scalar (1 element)")
  assertApproxDouble(lossData[0], -1.0, 0.001,
    "case1 PPO loss: ratio=1, A=+1 → loss = -1.0")

# ---------------------------------------------------------------------------
# Case 2 — ratio ≈ 2.394 > 1+eps, A > 0, upper clip wins → loss bounded
# ---------------------------------------------------------------------------
fn case2(): void =>
  print("case 2: ratio > 1+eps with A>0 (upper clip, bounded)\n")

  var logits: Tensor = Tensor.fromDoubles({2.0, 0.0}, 1, 2)
  var oldLogProbs: Tensor = Tensor.fromDoubles({-1.0}, 1, 1)
  var actionsOneHot: Tensor = Tensor.fromDoubles({1.0, 0.0}, 1, 2)
  var advantages: Tensor = Tensor.fromDoubles({1.0}, 1, 1)

  var loss: Tensor = sn_tensor_ppo_clipped_loss(
    logits, oldLogProbs, actionsOneHot, advantages, 0.2, 0.0)
  var lossData: double[] = loss.toDoubles()

  assertApproxDouble(lossData[0], -1.2, 0.001,
    "case2 PPO loss: r>1+eps, A=+1 → bounded at -(1+eps) = -1.2")

# ---------------------------------------------------------------------------
# Case 3 — ratio ≈ 0.324 < 1-eps, A < 0, lower clip wins → loss bounded
# ---------------------------------------------------------------------------
fn case3(): void =>
  print("case 3: ratio < 1-eps with A<0 (lower clip, bounded)\n")

  var logits: Tensor = Tensor.fromDoubles({2.0, 0.0}, 1, 2)
  var oldLogProbs: Tensor = Tensor.fromDoubles({1.0}, 1, 1)
  var actionsOneHot: Tensor = Tensor.fromDoubles({1.0, 0.0}, 1, 2)
  var advantages: Tensor = Tensor.fromDoubles({-1.0}, 1, 1)

  var loss: Tensor = sn_tensor_ppo_clipped_loss(
    logits, oldLogProbs, actionsOneHot, advantages, 0.2, 0.0)
  var lossData: double[] = loss.toDoubles()

  assertApproxDouble(lossData[0], 0.8, 0.001,
    "case3 PPO loss: r<1-eps, A=-1 → bounded at -(1-eps)*(-1) = +0.8")

# ---------------------------------------------------------------------------
# Case 4 — ratio ≈ 6.508 > 1+eps, A < 0, unclipped branch wins (recovery)
# ---------------------------------------------------------------------------
fn case4(): void =>
  print("case 4: ratio > 1+eps with A<0 (unclipped recovery)\n")

  var logits: Tensor = Tensor.fromDoubles({2.0, 0.0}, 1, 2)
  var oldLogProbs: Tensor = Tensor.fromDoubles({-2.0}, 1, 1)
  var actionsOneHot: Tensor = Tensor.fromDoubles({1.0, 0.0}, 1, 2)
  var advantages: Tensor = Tensor.fromDoubles({-1.0}, 1, 1)

  var loss: Tensor = sn_tensor_ppo_clipped_loss(
    logits, oldLogProbs, actionsOneHot, advantages, 0.2, 0.0)
  var lossData: double[] = loss.toDoubles()

  # e^1.873072 = 6.50843...; loss = -(-6.50843) = +6.50843
  assertApproxDouble(lossData[0], 6.50843, 0.005,
    "case4 PPO loss: r>1+eps, A=-1 → unclipped wins, loss ≈ +6.508")

# ---------------------------------------------------------------------------
# Case 5 — 2-sample mixed batch: case 1 + case 3
# Sample 0: per_sample = +1.0
# Sample 1: per_sample = -0.8 (lower clip)
# loss = -1/2 * (1.0 + -0.8) = -0.1
# ---------------------------------------------------------------------------
fn case5(): void =>
  print("case 5: 2-sample mixed batch (A>0 and A<0 together)\n")

  # Both samples have logits [2.0, 0.0], action class 0.
  # Sample 0: oldLogProb = -0.126928 (matching), advantage = +1.0
  # Sample 1: oldLogProb = +1.0      (huge),     advantage = -1.0
  var logits: Tensor = Tensor.fromDoubles(
    {2.0, 0.0, 2.0, 0.0}, 2, 2)
  var oldLogProbs: Tensor = Tensor.fromDoubles(
    {currentLogPiClass0(), 1.0}, 2, 1)
  var actionsOneHot: Tensor = Tensor.fromDoubles(
    {1.0, 0.0, 1.0, 0.0}, 2, 2)
  var advantages: Tensor = Tensor.fromDoubles({1.0, -1.0}, 2, 1)

  var loss: Tensor = sn_tensor_ppo_clipped_loss(
    logits, oldLogProbs, actionsOneHot, advantages, 0.2, 0.0)
  var lossData: double[] = loss.toDoubles()

  assertApproxDouble(lossData[0], -0.1, 0.001,
    "case5 PPO loss: mixed batch → -1/2*(1.0 + -0.8) = -0.1")

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
fn main(): void =>
  println("=== test_ppo_clipped_loss ===")
  println("")
  case1()
  case2()
  case3()
  case4()
  case5()
  summary()

  if failed() > 0 =>
    var zero: int = 0
    var _crash: int = 1 / zero
