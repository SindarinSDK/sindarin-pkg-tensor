import "sindarin-pkg-test/src/assert"
import "./assert/helpers"
import "../src/tensor"
import "../src/gnn"

# ===========================================================================
# test_crusher_policy_e2e.sn — Phase H / Part 3 Test 4
#
# Strict replacement for the previous tests/test_crusher_policy.sn. The
# old test trained the crusher policy model and PRINTED "ALL PASS" /
# "SOME FAILED" without any actual assertTrue calls, so a regression
# could flip every prediction to wrong and `make test` would still
# return exit 0. This version lives up to the doc's Part 3 Test 4
# contract:
#
# - All 15 samples predict argmax == correct class (strict asserts).
# - Jensen-Shannon divergence thresholds enforce learned separation:
# * JSD(SpeedUp[0], SpeedDown[0]) > 0.4
# * JSD(SpeedDown[0], Hold[0])    > 0.2
# - Determinism rerun: a second model trained with the same seed
# produces identical probability values to within 1e-6.
# - Crash-on-fail via `failed() > 0 ⇒ 1/0` so regressions turn
# `make test` red instead of green.
#
# The data, architecture, and optimizer settings match
# `skynet/config/crusher/model-engine.yaml` and the original test so
# that a pass here is a direct proof that the crusher production
# configuration learns a state-conditional policy on canonical samples.
#
# 24 features: vsd_freq, amps (×6), weight, speed, iso (×6), flags (×5), kw (×3)
# 3 actions: speed_up=0, speed_down=1, hold=2
# ===========================================================================

# ---------------------------------------------------------------------------
# Raw sample data — hand-picked by the original test author to cover
# the three canonical crusher regimes.
# ---------------------------------------------------------------------------

