import "sindarin-pkg-test/src/assert"
import "../src/tensor"
import "../src/gnn"

# Test sn_train_step with a multi-node graph batch.
# This exercises the graph-aware training path:
# sn_train_init → sn_graph_begin → params → input → forward → sn_train_step → sn_graph_end

fn main(): void =>
  println("test_train_step: graph-aware training with real topology")

  # --- Create a small GCN (no batch norm / attention issues) ---
  # Using GCN with 1 layer, dropout=0 to minimize non-differentiable ops.
  var config: GnnConfig = GnnConfig {
    inputDim: 3,
    hiddenDim: 4,
    numActions: 2,
    numLayers: 1,
    arch: "gcn",
    dropoutRate: 0.0
  }
  var model: Gnn = Gnn.create(config)
  var nParams: int = len(model.parameters())
  println($"  model created: {nParams} params")

  # --- Build a batch of 2 graphs ---
  #
  # Graph 0: 3 nodes, 2 edges (0→1, 1→2)
  # Graph 1: 2 nodes, 1 edge  (0→1)
  #
  # After batching: 5 total nodes, 3 total edges
  # Batch index: [0, 0, 0, 1, 1]
  # Edge offsets: graph1 edges offset by 3 (graph0 node count)

  var totalNodes: int = 5
  var totalEdges: int = 3
  var featureDim: int = 3
  var numGraphs: int = 2
  var numActions: int = 2

  # Node features: 5 nodes × 3 features
  var features: double[] = {
    1.0, 0.0, 0.5,
    0.0, 1.0, 0.5,
    0.5, 0.5, 1.0,
    0.8, 0.2, 0.0,
    0.2, 0.8, 0.0
  }

  # Edge index: [src0, src1, src2] [dst0, dst1, dst2]
  # Graph 0 edges: 0→1, 1→2
  # Graph 1 edges: 3→4 (offset by 3)
  var edgeData: double[] = {
    0.0, 1.0, 3.0,
    1.0, 2.0, 4.0
  }
  var edgeWeights: double[] = {1.0, 1.0, 1.0}

  # Batch index: node → graph assignment
  var batchIndex: double[] = {0.0, 0.0, 0.0, 1.0, 1.0}

  var batchTensors: GraphTensors = GraphTensors {
    nodeFeatures: Tensor.fromDoubles(features, totalNodes, featureDim),
    edgeIndex: Tensor.fromDoubles(edgeData, 2, totalEdges),
    edgeWeight: Tensor.fromDoubles(edgeWeights, 1, totalEdges),
    batchIndex: Tensor.fromDoubles(batchIndex, totalNodes, 1),
    numNodes: totalNodes,
    numEdges: totalEdges,
    featureDim: featureDim
  }

  # --- One-hot labels: graph 0 → action 0, graph 1 → action 1 ---
  var labels: double[] = {
    1.0, 0.0,
    0.0, 1.0
  }

  # --- Advantage weights (shifted to [0, 2]) ---
  var weights: double[] = {1.5, 0.5}

  # --- Test: inference before training ---
  println("  inference before training...")
  var preOutput: GnnOutput = model.forward(batchTensors, false)
  var preProbs: double[] = preOutput.probs.toDoubles()
  println($"  graph 0 probs: [{preProbs[0]}, {preProbs[1]}]")
  if len(preProbs) >= 4 =>
    println($"  graph 1 probs: [{preProbs[2]}, {preProbs[3]}]")

  # --- Train: one step ---
  println("  sn_train_init...")
  sn_train_init(0.01, 0.0)

  println("  sn_graph_begin...")
  sn_graph_begin()

  var params: Tensor[] = model.parameters()
  for var p: int = 0; p < len(params); p++ =>
    sn_graph_param(params[p])

  var input: Tensor = sn_graph_input(totalNodes, featureDim)
  var recordGraph: GraphTensors = GraphTensors {
    nodeFeatures: input,
    edgeIndex: batchTensors.edgeIndex,
    edgeWeight: batchTensors.edgeWeight,
    batchIndex: batchTensors.batchIndex,
    numNodes: totalNodes,
    numEdges: totalEdges,
    featureDim: featureDim
  }

  println("  forward pass (recording)...")
  var output: GnnOutput = model.forward(recordGraph, true)

  println("  sn_train_step...")
  var nodeData: double[] = batchTensors.nodeFeatures.toDoubles()
  var loss: double = sn_train_step(output.logits, input, nodeData, labels, weights, numGraphs)

  println($"  loss = {loss}")
  sn_graph_end()
  sn_train_finish()

  # --- Test: inference after training ---
  println("  inference after training...")
  var postOutput: GnnOutput = model.forward(batchTensors, false)
  var postProbs: double[] = postOutput.probs.toDoubles()
  println($"  graph 0 probs: [{postProbs[0]}, {postProbs[1]}]")
  if len(postProbs) >= 4 =>
    println($"  graph 1 probs: [{postProbs[2]}, {postProbs[3]}]")

  # Basic checks
  assert(loss >= 0.0, "loss should be non-negative")
  println("  PASSED")
