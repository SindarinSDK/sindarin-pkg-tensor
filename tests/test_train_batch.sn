import "../src/tensor"
import "../src/gnn"

# ===========================================================================
# Test training with various batch sizes.
# Verifies that Gnn.train() handles different batch sizes against a
# homogeneous (single-node) graph training set.
# ===========================================================================

fn singleNode(features: double[], featureDim: int): GraphTensors =>
  return GraphTensors {
    nodeFeatures: Tensor.fromDoubles(features, 1, featureDim),
    edgeIndex: Tensor.fromDoubles({0.0, 0.0}, 2, 1),
    edgeWeight: Tensor.fromDoubles({1.0}, 1, 1),
    batchIndex: Tensor.fromDoubles({0.0}, 1, 1),
    numNodes: 1, numEdges: 1, featureDim: featureDim
  }

fn trainAndReport(batchSize: int, featureDim: int, numActions: int,
  graphs: GraphTensors[], labels: double[],
  weights: double[], epochs: int): TrainResult =>
  var config: GnnConfig = {
    inputDim: featureDim, hiddenDim: 16, numActions: numActions,
    numLayers: 2, arch: "gcn", dropoutRate: 0.0
  }
  var model: Gnn = Gnn.createWithSeed(config, 42l)
  var opt: OptimizerParams = AdamW.create(0.01, 0.0).params()
  return model.train(graphs, labels, weights, opt, epochs, batchSize, 0.0, 42l)

fn main(): void =>
  println("=== Test training with different batch sizes ===")
  println("")

  var featureDim: int = 8
  var numActions: int = 3
  var numSamples: int = 24

  # Generate 24 samples: 8 per class with distinct patterns
  var graphs: GraphTensors[] = {}
  var labels: double[] = {}
  var weights: double[] = {}
  for var s: int = 0; s < numSamples; s++ =>
    var cls: int = s % numActions
    var sampleFeatures: double[] = {}
    for var f: int = 0; f < featureDim; f++ =>
      if f == cls =>
        sampleFeatures.push(1.0)
      else if f == cls + numActions =>
        sampleFeatures.push(0.8)
      else =>
        sampleFeatures.push(0.1)
    graphs.push(singleNode(sampleFeatures, featureDim))
    for var a: int = 0; a < numActions; a++ =>
      if a == cls =>
        labels.push(1.0)
      else =>
        labels.push(0.0)
    weights.push(1.0)

  # --- batchSize=1 (baseline) ---
  var r1: TrainResult = trainAndReport(1, featureDim, numActions, graphs, labels, weights, 30)
  println($"  batch=1:  loss={r1.loss}, accuracy={r1.accuracy}")

  # --- batchSize=4 ---
  var r4: TrainResult = trainAndReport(4, featureDim, numActions, graphs, labels, weights, 30)
  println($"  batch=4:  loss={r4.loss}, accuracy={r4.accuracy}")

  # --- batchSize=8 ---
  var r8: TrainResult = trainAndReport(8, featureDim, numActions, graphs, labels, weights, 30)
  println($"  batch=8:  loss={r8.loss}, accuracy={r8.accuracy}")

  # --- batchSize=24 (full batch) ---
  var r24: TrainResult = trainAndReport(24, featureDim, numActions, graphs, labels, weights, 30)
  println($"  batch=24: loss={r24.loss}, accuracy={r24.accuracy}")

  println("")

  # Verify all converged (loss should be reasonably low after 30 epochs).
  # Accuracy is currently a placeholder (0.0) — see Gnn.train() TODO,
  # full TrainResult diagnostics land in 2c.5.
  var allOk: bool = true
  if r1.loss > 1.0 =>
    println("  FAIL: batch=1 loss too high")
    allOk = false
  if r4.loss > 1.0 =>
    println("  FAIL: batch=4 loss too high")
    allOk = false
  if r8.loss > 1.0 =>
    println("  FAIL: batch=8 loss too high")
    allOk = false
  if r24.loss > 1.0 =>
    println("  FAIL: batch=24 loss too high")
    allOk = false

  if allOk =>
    println("  ALL PASS")
  else =>
    println("  SOME TESTS FAILED")
    assert(false, "test_train_batch: one or more batch sizes failed")
