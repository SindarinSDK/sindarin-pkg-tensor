{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "ggml",
  "version": "0.9.11",
  "port-version": 2,
  "description": "Tensor library for machine learning — RealOrko fork with sindarin-pkg-tensor patches.",
  "homepage": "https://github.com/RealOrko/ggml",
  "license": "MIT",
  "supports": "!uwp",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "cuda": {
      "description": "Enable CUDA backend"
    },
    "metal": {
      "description": "Enable Metal backend (macOS only)",
      "supports": "osx"
    }
  }
}
