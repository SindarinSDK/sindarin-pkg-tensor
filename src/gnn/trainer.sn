# ==============================================================================
# sindarin-pkg-tensor/src/gnn/trainer.sn — Trainer<M, S, O> + TrainConfig + TrainResult
# ==============================================================================
#
# The canonical training path. `Trainer<M, S, O>` owns one complete
# training loop that is strategy-aware via its type parameter `S:
# TrainStrategy`. The old `Gnn.trainCore` — ~500 lines branching on
# `lossKind: str` for supervised vs PPO — is replaced by this single
# implementation, with the four loss-kind-specific spots delegated to
# the strategy:
#
# 1. Pre-record forward-prob snapshot   -> strategy.prepare(...)
# 2. Extra static input tensor alloc    -> strategy.buildLoss(...)
# 3. Loss op construction               -> strategy.buildLoss(...)
# 4. Per-epoch native driver dispatch   -> strategy.runEpoch(ctx)
#
# Type parameters:
#
# M : model type. Unconstrained — Sindarin's structural method
# dispatch resolves `self.model.forward(...)` / `.parameters()`
# / `.config.numActions` at instantiation time. Keeping M
# unconstrained means this file does not need to `import "../gnn"`
# for the Gnn struct, which would create an import cycle with
# the gnn.sn facade.
#
# S : train strategy. WeightedCrossEntropy or PpoClipped (or any
# struct satisfying the TrainStrategy interface).
#
# O : optimizer. AdamW, Sgd, or OptimizerParams itself (all satisfy
# the Optimizer interface via a params() method).
#
# TrainResult lives in this file because it is the canonical return
# type of Trainer.run() — every caller-visible training entry point
# funnels through here.
# ==============================================================================

import "../tensor"
import "../tensor/panic"
import "../tensor/record"
import "../tensor/metrics"
import "../tensor/optim"
import "./strategy"
import "sindarin-pkg-sdk/src/core/random"
import "sindarin-pkg-sdk/src/core/math"
import "sindarin-pkg-sdk/src/core/fields"

# ---------------------------------------------------------------------------
# TrainConfig — caller-facing training hyperparameters.
# ---------------------------------------------------------------------------

struct TrainConfig =>
  epochs: int
  batchSize: int
  seed: long
  valSplit: double
  # Phase 1.1: if true, Trainer.run normalizes the caller-supplied
  # `weights` array (interpreted as per-sample advantages in the RL
  # case) to zero mean and unit std before handing it to the strategy.
  # Matches the standard PPO "advantage normalization" implementation
  # detail (SB3, CleanRL, Huang et al. 2022 "37 details"). Default
  # false for backwards compatibility — existing supervised callers
  # that pass constant-1.0 weights do not want their weights zeroed.
  #
  # Semantics: the normalization is over the FULL input weights array
  # (not per-minibatch), applied once before training starts. This
  # matches how SB3 and CleanRL do it — GAE is computed on the full
  # rollout, then normalized across the whole dataset before shuffling
  # into minibatches. If the population std is below `ADV_NORM_EPS`
  # (e.g. all weights identical), normalization is skipped to avoid
  # divide-by-near-zero producing NaNs. The diagnostic fields
  # `weightSumIn` / `weightVarianceIn` on TrainResult still report the
  # statistics of the ORIGINAL input weights, not the normalized form
  # — they're the caller-facing "here's what you passed in" sanity
  # check. The strategy consumes the normalized form internally.
  normalizeAdvantages: bool
  # Phase 1.2: if true, Trainer.run computes per-feature population
  # mean and std over the full padded featuresHost buffer BEFORE
  # training starts, writes them into the model's `obsMean`/`obsStd`
  # fields, sets `obsNormEnabled=true`, and pre-normalizes the host
  # buffer in place so the recorded loss graph sees normalized
  # features. After training, subsequent `forward()` calls on the
  # same model will also apply the stored normalization via the
  # Gnn.forward host-side preprocess path — so inference is
  # consistent with training automatically. Default false so existing
  # tests and single-domain callers keep the zero-touch behaviour.
  #
  # The stats are computed fresh per Trainer.run call, matching the
  # "train-then-promote" pattern skynet uses — no Welford running
  # average across sessions, no risk of stale stats polluting a new
  # training set with a very different feature distribution. The
  # caller controls the session boundary.
  normalizeObservations: bool
  # Phase 1.3: learning-rate schedule. Applied per-epoch by Trainer.run
  # to the base optimizer lr before calling the native driver.
  # Default is `LrSchedule.constant()` — no warmup, no decay, behaves
  # identically to pre-Phase-1.3 runs so existing tests and skynet
  # call sites keep working with zero config changes. See
  # src/tensor/optim.sn::LrSchedule for the schedule kinds and
  # `effectiveLr` semantics.
  lrSchedule: LrSchedule
  # Phase 1.4: global-norm gradient clip threshold. If > 0.0, the
  # training loop bounds the L2 norm of each batch's parameter delta
  # to this value, scaling down the update post-hoc when it exceeds
  # the bound. Prevents a single bad batch from destroying the
  # policy — the critical "don't kill a training run" safeguard on
  # cold-start / noisy-advantage regimes. 0.0 disables (default).
  # See src/native/tensor_train.sn.c for the implementation rationale
  # (delta clipping vs true gradient clipping under AdamW moments).
  gradClipNorm: double
  # Phase 2: per-epoch trust-region early stop. If > 0.0, after each
  # epoch the trainer computes the mean KL divergence between the
  # current policy's predictions and the initial-snapshot
  # predictions (both over the full training set) and breaks the
  # epoch loop the first time the mean exceeds this threshold. The
  # model at exit reflects the state at the last completed epoch
  # (the "safe" state), and TrainResult.stoppedEarly is true.
  #
  # Follows the SB3 `target_kl` convention — a bounded "how far has
  # the policy moved from where it started" check that prevents a
  # single training run from destroying a good initial policy when
  # the advantages or gradients are unexpectedly large. Works for
  # any strategy (PPO or weighted CE) because the initial-probs
  # snapshot is computed by the trainer regardless of what the
  # strategy's prepare() does with it.
  #
  # Default 0.0 disables the check entirely (no extra forward passes,
  # zero overhead). A typical enabled value is 0.01 to 0.02 for PPO
  # — matches SB3's recommendation.
  targetKl: double
  # Optimizer state persistence. When optStateRestorePath is non-empty,
  # the training loop loads AdamW m/v moments + iter counter from a
  # `.opt` sidecar file before the first epoch, giving the optimizer
  # continuity across training rounds. When optStateSavePath is non-
  # empty, the moments are saved after the last epoch. Both default to
  # "" (disabled).
  optStateRestorePath: str
  optStateSavePath: str
  # PPO clip epsilon for clip-fraction diagnostics. When > 0.0,
  # Trainer.run() computes the fraction of policy ratios that were
  # clipped per epoch and reports it in TrainResult.clipFracCurve.
  # Set to the PPO strategy's epsilon (typically 0.2). Default 0.0
  # disables clip-fraction tracking.
  clipEpsilon: double

  static fn create(epochs: int, batchSize: int, seed: long): TrainConfig =>
    return TrainConfig {
      epochs: epochs,
      batchSize: batchSize,
      seed: seed,
      valSplit: 0.0,
      normalizeAdvantages: false,
      normalizeObservations: false,
      lrSchedule: LrSchedule.constant(),
      gradClipNorm: 0.0,
      targetKl: 0.0,
      optStateRestorePath: "",
      optStateSavePath: "",
      clipEpsilon: 0.0
    }

# ---------------------------------------------------------------------------
# TrainResult — diagnostics + headline scalars returned by Trainer.run().
#
# Top-line scalars (loss, accuracy, epochs) are the headline values;
# the *Curve / *Norm* / *Delta arrays are the Phase C diagnostics
# from docs/issues/golden-path.md §2.4 and Part 7. Use them to detect:
#
# loss diverging or NaNing           -> lossCurve
# optimizer not moving the params    -> gradNormCurve, paramMaxAbsDelta
# garbage in / garbage out           -> inputMean, inputStd
# caller dropped the weight vector   -> weightSumIn, weightVarianceIn
# weight-update regression           -> paramNormBefore vs paramNormAfter
#
# Per-parameter arrays (paramNorm*, paramMaxAbsDelta) are indexed in
# the same order as the model's parameters() method returns them.
#
# Semantic note on `loss`: this is the FINAL EPOCH average loss (the
# tail of lossCurve), not the across-epoch average. Use lossCurve for
# the full trajectory.
#
# Semantic note on `gradNormCurve`: this is the per-epoch L2 of the
# parameter DELTA, i.e. L2(params_after_epoch - params_before_epoch).
# For AdamW this is proportional to the optimizer's effective step
# magnitude over the epoch. Both answer "is the model moving?" — the
# param-delta form is robust against ggml zeroing the .grad field
# after backward.
# ---------------------------------------------------------------------------

struct TrainResult =>
  loss: double
  accuracy: double
  epochs: int
  lossCurve: double[]
  gradNormCurve: double[]
  paramNormBefore: double[]
  paramNormAfter: double[]
  paramMaxAbsDelta: double[]
  weightSumIn: double
  weightVarianceIn: double
  inputMean: double
  inputStd: double
  # Phase 1.3: per-epoch effective learning rate actually used by the
  # optimizer. Length == epochs. For the default
  # `LrSchedule.constant()` this is a flat vector of the caller's
  # base lr; for warmup + decay schedules it's the curve produced by
  # `LrSchedule.effectiveLr(baseLr, epoch, totalEpochs)`. Consumers
  # can use this to debug "did my schedule actually take effect" and
  # to plot the learning-rate trajectory alongside lossCurve.
  lrCurve: double[]
  # Phase 2: per-epoch mean KL divergence between the current policy
  # and the initial-snapshot policy (both over the full training
  # set). Computed only when TrainConfig.targetKl > 0.0; for
  # disabled runs this is an empty array. Length equals the number
  # of epochs actually run (which may be less than config.epochs
  # if stoppedEarly is true).
  klCurve: double[]
  # Phase 2: true if training was aborted mid-loop by the Phase 2
  # target-KL drift check. When this is set, `epochs` reflects the
  # number of COMPLETED epochs (which will be less than
  # config.epochs), lossCurve / gradNormCurve / lrCurve / klCurve
  # have lengths matching the completed epoch count, and the model's
  # final parameters are the state after the last completed epoch.
  stoppedEarly: bool
  # Phase 4: per-epoch mean value-function loss, computed post-hoc in
  # Sindarin by running model.forward on every training sample at the
  # end of each epoch and taking mean((V_θ(s) - V_target)^2). Only
  # populated when the model has a value head (valueHeadEnabled on
  # the concrete model before construction); for non-value-head runs
  # this is an empty array.
  #
  # Why post-hoc rather than reading the native loss term: the native
  # PPO loss graph produces a single scalar that combines the
  # policy, entropy, and VF terms — splitting them out would require
  # plumbing a second readback through ggml_opt_eval. Re-running
  # forward() at epoch-end is the same cost as the Phase 2 target-KL
  # drift check already pays (when targetKl > 0), and it's only
  # incurred when the caller actually enabled a value head, so
  # existing tests don't see any extra work.
  #
  # Length matches the number of COMPLETED epochs (same semantics as
  # lossCurve / klCurve under target-KL early stop).
  valueLossCurve: double[]
  # Per-epoch clip fraction: fraction of policy ratios that fell
  # outside [1-epsilon, 1+epsilon] after each epoch's training step.
  # Healthy range: 0.1-0.3. Zero means the policy isn't moving. >0.5
  # means updates are too aggressive. Only populated when
  # TrainConfig.clipEpsilon > 0.0; otherwise empty.
  clipFracCurve: double[]

# ---------------------------------------------------------------------------
# Trainer<M, S, O>
# ---------------------------------------------------------------------------

struct Trainer < M, S: TrainStrategy, O: Optimizer > =>
  model: M
  config: TrainConfig
  optimizer: O
  strategy: S

  # Note: construct via struct literal, not a static factory. The
  # `static fn create(model: M, ...): Trainer<M, S, O>` form triggers
  # a "Trainer.create argument 1: type mismatch" error in the current
  # Sindarin compiler when instantiated with a concrete model type —
  # the type-checker doesn't bind M to the argument. Struct-literal
  # construction works correctly and is the idiomatic form:
  #
  # var trainer: Trainer<Gnn, WeightedCrossEntropy, OptimizerParams> =
  # Trainer<Gnn, WeightedCrossEntropy, OptimizerParams> {
  # model: model, config: cfg, optimizer: opt, strategy: strat
  # }

  # -------------------------------------------------------------------------
  # Run the full training loop.
  #
  # `targets` is either one-hot labels (supervised) or one-hot actions
  # (RL), depending on the strategy. `weights` is either sample weights
  # (supervised) or per-sample advantages (RL). Shape conventions match
  # the native training driver's contract.
  #
  # Heterogeneous batching: this entry point handles graphs with
  # VARIABLE `numNodes` and `numEdges`. The only precondition is that
  # every graph share the same `featureDim`. Internally each sample is
  # padded to `maxNodes = max(graphs[i].numNodes)` with zero features
  # and a zero adjacency, then re-uploaded per minibatch into a
  # fixed-shape recorded graph. The mean-pool denominator uses the
  # REAL node count per graph, so padded rows do not dilute the
  # per-graph embedding. See docs/issues/heterogeneous-graph-batching.md.
  # -------------------------------------------------------------------------
  fn run(graphs: GraphTensors[], targets: double[], weights: double[]): TrainResult =>
    var optParams: OptimizerParams = self.optimizer.params()
    var epochs: int = self.config.epochs
    var batchSize: int = self.config.batchSize

    # --- Early return for empty / degenerate inputs. -----------------------
    if len(graphs) == 0 || epochs <= 0 || batchSize <= 0 =>
      var emptyD: double[] = {}
      var emptyD2: double[] = {}
      var emptyD3: double[] = {}
      var emptyD4: double[] = {}
      var emptyD5: double[] = {}
      var emptyD6: double[] = {}
      var emptyD7: double[] = {}
      var emptyD8: double[] = {}
      var emptyD9: double[] = {}
      return TrainResult {
        loss: 0.0,
        accuracy: 0.0,
        epochs: 0,
        lossCurve: emptyD,
        gradNormCurve: emptyD2,
        paramNormBefore: emptyD3,
        paramNormAfter: emptyD4,
        paramMaxAbsDelta: emptyD5,
        weightSumIn: 0.0,
        weightVarianceIn: 0.0,
        inputMean: 0.0,
        inputStd: 0.0,
        lrCurve: emptyD6,
        klCurve: emptyD7,
        stoppedEarly: false,
        valueLossCurve: emptyD8,
        clipFracCurve: emptyD9
      }

    var totalSamples: int = len(graphs)
    var featureDim: int = graphs[0].featureDim
    var numClasses: int = self.model.config.numActions

    # --- featureDim is the only true shape precondition. --------------------
    for var i: int = 1; i < totalSamples; i++ =>
      if graphs[i].featureDim != featureDim =>
        panic($"Trainer.run: graph {i} has featureDim={graphs[i].featureDim}, expected {featureDim} (matching graph 0). All training graphs must share featureDim.")
      if graphs[i].numNodes <= 0 =>
        panic($"Trainer.run: graph {i} has numNodes={graphs[i].numNodes}; must be > 0.")

    # --- Compute maxNodes for the padding ceiling. -------------------------
    var maxNodes: int = graphs[0].numNodes
    for var i: int = 1; i < totalSamples; i++ =>
      if graphs[i].numNodes > maxNodes =>
        maxNodes = graphs[i].numNodes

    # --- Strategy prep: run forward in inference mode over every sample,
    # flatten the resulting probabilities into one double[], and hand
    # them to the strategy so PpoClipped can derive oldLogProbsHost.
    # WeightedCrossEntropy ignores the call. The forward pass runs
    # BEFORE sn_graph_begin() so the pool slots it allocates aren't
    # record-mode tensors.
    #
    # Phase 2: the same flattened-probs buffer doubles as the initial
    # policy snapshot for the target-KL drift check. If
    # `config.targetKl > 0.0`, we keep this array around and re-
    # compute its equivalent after each epoch, then compare via
    # per-sample KL divergence. The initial snapshot reflects the
    # model state at the *start* of this run — so the drift is
    # measured against where we started, not where the previous
    # epoch left off. This matches SB3's target_kl semantics.
    # Phase 4: collect the pre-record value estimates in the same loop
    # as the probs. For models without a value head, forward() returns
    # the (1,1) zero placeholder so initialValuesFlat is zero-padded
    # to one entry per sample — the PpoClipped strategy still produces
    # a valueTargetsHost (== advantages + zeros == advantages) which
    # the loss op ignores whenever valueCoeff=0. The cost of the
    # extra .toDoubles() call is one per sample and is dominated by
    # the existing probs readback.
    var initialProbsFlat: double[] = {}
    var initialValuesFlat: double[] = {}
    for var i: int = 0; i < totalSamples; i++ =>
      var cpIter: long = self.model.checkpoint()
      var out: GnnOutput = self.model.forward(graphs[i], false)
      var probs: double[] = out.probs.toDoubles()
      for var j: int = 0; j < len(probs); j++ =>
        initialProbsFlat.push(probs[j])
      var v: double[] = out.valueEstimate.toDoubles()
      var vScalar: double = 0.0
      if len(v) > 0 =>
        vScalar = v[0]
      initialValuesFlat.push(vScalar)
      self.model.restore(cpIter)
    # VF targets must be computed from the RAW advantages, not the
    # advantage-normalized form — otherwise V_target = (normalized adv)
    # + V_old drifts away from the real GAE returns and the value head
    # learns a miscalibrated scalar. Normalized advantages are only
    # the right signal for the POLICY gradient term; the value head
    # regresses against un-normalized returns.
    self.strategy.prepare(
      initialProbsFlat, initialValuesFlat,
      totalSamples, numClasses, targets, weights)

    # --- Aggregation normalization mode: gat -> sum, gcn -> sum_normalized,
    # sage -> mean. All layers in one model share an architecture.
    var normMode: str = "sum"
    if self.model.config.arch == "gcn" =>
      normMode = "sum_normalized"
    if self.model.config.arch == "sage" =>
      normMode = "mean"

    # --- Build per-sample padded host buffers. ------------------------------
    var featuresHost: double[] = {}
    var adjHost: double[] = {}
    var realNodeCountHost: double[] = {}

    for var i: int = 0; i < totalSamples; i++ =>
      var nNodes: int = graphs[i].numNodes
      var nEdges: int = graphs[i].numEdges
      realNodeCountHost.push(nNodes.toDouble())

      # Pad features: copy real (nNodes * featureDim) doubles, then
      # push zeros for the (maxNodes - nNodes) padding rows.
      var srcFeats: double[] = graphs[i].nodeFeatures.toDoubles()
      var realLen: int = nNodes * featureDim
      for var j: int = 0; j < realLen; j++ =>
        featuresHost.push(srcFeats[j])
      for var j: int = realLen; j < maxNodes * featureDim; j++ =>
        featuresHost.push(0.0)

      # Build the per-sample dense adjacency (maxNodes * maxNodes),
      # zero beyond the real node count, with normalization baked in.
      var adj: double[] = {}
      for var j: int = 0; j < maxNodes * maxNodes; j++ =>
        adj.push(0.0)

      var ei: double[] = graphs[i].edgeIndex.toDoubles()
      var ew: double[] = graphs[i].edgeWeight.toDoubles()

      # edgeIndex layout: row 0 = sources, row 1 = destinations.
      for var k: int = 0; k < nEdges; k++ =>
        var s: int = ei[k].toInt()
        var d: int = ei[nEdges + k].toInt()
        var w: double = ew[k]
        if s >= 0 && s < nNodes && d >= 0 && d < nNodes =>
          adj[d * maxNodes + s] = adj[d * maxNodes + s] + w

      # Apply per-row normalization for "mean" / "sum_normalized" modes.
      if normMode == "mean" || normMode == "sum_normalized" =>
        var cnt: double[] = {}
        for var d: int = 0; d < maxNodes; d++ =>
          cnt.push(0.0)
        for var k: int = 0; k < nEdges; k++ =>
          var d: int = ei[nEdges + k].toInt()
          if d >= 0 && d < nNodes =>
            cnt[d] = cnt[d] + 1.0
        for var d: int = 0; d < nNodes; d++ =>
          var c: double = cnt[d]
          if c <= 0.0 =>
            c = 1.0
          for var s: int = 0; s < nNodes; s++ =>
            adj[d * maxNodes + s] = adj[d * maxNodes + s] / c

      for var j: int = 0; j < maxNodes * maxNodes; j++ =>
        adjHost.push(adj[j])

    # --- Build a padded template for the recorded forward graph. ----------
    var nodesPerBatch: int = batchSize * maxNodes

    var initFeatures: double[] = {}
    for var i: int = 0; i < nodesPerBatch * featureDim; i++ =>
      initFeatures.push(0.0)

    var templateEdges: double[] = {}
    for var i: int = 0; i < nodesPerBatch; i++ =>
      templateEdges.push(i.toDouble())
    for var i: int = 0; i < nodesPerBatch; i++ =>
      templateEdges.push(i.toDouble())
    var templateWeights: double[] = {}
    for var i: int = 0; i < nodesPerBatch; i++ =>
      templateWeights.push(1.0)

    var templateBatchIndex: double[] = {}
    for var b: int = 0; b < batchSize; b++ =>
      for var n: int = 0; n < maxNodes; n++ =>
        templateBatchIndex.push(b.toDouble())

    var initLabels: double[] = {}
    for var i: int = 0; i < batchSize * numClasses; i++ =>
      initLabels.push(0.0)
    var initWeights: double[] = {}
    for var i: int = 0; i < batchSize; i++ =>
      initWeights.push(0.0)

    # --- Phase C: input + weight statistics over the host buffers. --------
    var inputMean: double = 0.0
    var inputStd: double = 0.0
    var nFeat: int = len(featuresHost)
    if nFeat > 0 =>
      var sumIn: double = 0.0
      for var i: int = 0; i < nFeat; i++ =>
        sumIn = sumIn + featuresHost[i]
      inputMean = sumIn / nFeat.toDouble()
      var sqDiff: double = 0.0
      for var i: int = 0; i < nFeat; i++ =>
        var d: double = featuresHost[i] - inputMean
        sqDiff = sqDiff + d * d
      inputStd = sqrt(sqDiff / nFeat.toDouble())

    var weightSumIn: double = 0.0
    var weightVarianceIn: double = 0.0
    var nW: int = len(weights)
    if nW > 0 =>
      for var i: int = 0; i < nW; i++ =>
        weightSumIn = weightSumIn + weights[i]
      var wMean: double = weightSumIn / nW.toDouble()
      var wSqDiff: double = 0.0
      for var i: int = 0; i < nW; i++ =>
        var d: double = weights[i] - wMean
        wSqDiff = wSqDiff + d * d
      weightVarianceIn = wSqDiff / nW.toDouble()

    # Phase 1.1: advantage normalization. If enabled, replace `weights`
    # with (weights - mean) / (std + eps) over the full input array.
    # The diagnostic fields above are computed against the ORIGINAL
    # input so callers can sanity-check what they passed in.
    var effectiveWeights: double[] = weights
    if self.config.normalizeAdvantages && nW > 0 =>
      var wMean2: double = weightSumIn / nW.toDouble()
      var wStd: double = sqrt(weightVarianceIn)
      var advNormEps: double = 0.00000001
      # Guard against degenerate zero-variance inputs (e.g. all
      # weights identical). Skipping is the right call — dividing by
      # ~0 would amplify floating-point noise into huge spurious
      # advantages. The caller's data is just uninformative here.
      if wStd > advNormEps =>
        var normed: double[] = {}
        for var i: int = 0; i < nW; i++ =>
          normed.push((weights[i] - wMean2) / (wStd + advNormEps))
        effectiveWeights = normed

    # Phase 1.2: observation normalization. If the caller enabled obs
    # norm on the model *before* constructing the trainer (via
    # `Gnn.enableObservationNormalization(graphs)`) AND this config
    # opts in, pre-normalize featuresHost in place using the model's
    # stored per-feature mean/std. The record-mode forward will skip
    # its own obs-norm application when training=true (see the
    # comment in Gnn.forward), so we own the host-side transform here
    # and the recorded graph consumes already-normalized features.
    #
    # Why the stats come from the model rather than being computed
    # here: Sindarin's generic dispatch through the Trainer's type
    # parameter `M` does not propagate primitive-field mutations back
    # to the caller's original struct — the Trainer holds a value
    # copy of the model for the duration of the run. Having the
    # caller seed the stats on the concrete Gnn before construction
    # side-steps this entirely.
    if self.config.normalizeObservations && self.model.obsNormEnabled =>
      var modelMean: double[] = self.model.obsMean
      var modelStd: double[] = self.model.obsStd
      for var s: int = 0; s < totalSamples; s++ =>
        var realNodes: int = realNodeCountHost[s].toInt()
        var base: int = s * maxNodes * featureDim
        for var r: int = 0; r < realNodes; r++ =>
          for var c: int = 0; c < featureDim; c++ =>
            var pos: int = base + r * featureDim + c
            featuresHost[pos] = (featuresHost[pos] - modelMean[c]) / modelStd[c]

    # Phase 1.4: install the grad-clip threshold into the native
    # training driver. The global is reset to 0.0 after the loop so
    # a subsequent Trainer.run with a different gradClipNorm (or
    # none) starts from a clean slate.
    sn_graph_set_grad_clip_norm(self.config.gradClipNorm)

    # Optimizer state: set the deferred restore path so the native lazy-
    # init block uploads saved AdamW moments on the first training batch.
    if self.config.optStateRestorePath != "" =>
      sn_opt_state_set_restore(self.config.optStateRestorePath + ".opt")

    # --- Open a record session and build the static training graph. -------
    var session: RecordSession = RecordSession.open()

    # Register PARAMs (DISCARD return — see docs/issues/compiler-problems.29.md).
    var params: Tensor[] = self.model.parameters()
    for var i: int = 0; i < len(params); i++ =>
      session.param(params[i])

    # --- Phase C: snapshot per-parameter pre-train state. ------------------
    var nParams: int = len(params)
    var initialData: double[][] = {}
    var rollingData: double[][] = {}
    var paramNormBefore: double[] = {}
    for var i: int = 0; i < nParams; i++ =>
      var snap: double[] = params[i].toDoubles()
      initialData.push(snap)
      rollingData.push(snap)
      paramNormBefore.push(params[i].norm())

    var nodeFeaturesInput: Tensor = session.inputData(initFeatures, nodesPerBatch, featureDim)
    var labelsInput: Tensor = session.inputData(initLabels, batchSize, numClasses)
    var weightsInput: Tensor = session.inputData(initWeights, batchSize, 1)

    var inputGraph: GraphTensors = {
      nodeFeatures: nodeFeaturesInput,
      edgeIndex: Tensor.fromDoubles(templateEdges, 2, nodesPerBatch),
      edgeWeight: Tensor.fromDoubles(templateWeights, 1, nodesPerBatch),
      batchIndex: Tensor.fromDoubles(templateBatchIndex, nodesPerBatch, 1),
      numNodes: nodesPerBatch,
      numEdges: nodesPerBatch,
      featureDim: featureDim
    }

    var output = self.model.forward(inputGraph, true)

    # Strategy builds the loss. PpoClipped allocates its extra
    # oldLogProbsInput / valueTargetsInput / oldValuesInput tensors
    # via session.inputData here and stashes them on self for
    # runEpoch. The valueEstimates tensor from the forward pass is
    # threaded through so PpoClipped can wire it into the VF loss
    # term; for models without a value head it's the (1,1) zero
    # placeholder and the loss op gates the VF term away.
    var loss: Tensor = self.strategy.buildLoss(
      session, output.logits, output.valueEstimate,
      labelsInput, weightsInput, batchSize)

    # --- Epoch loop with deterministic across-batch shuffling. -------------
    var nBatches: int = totalSamples / batchSize
    if nBatches < 1 =>
      nBatches = 1
    var batchOrder: double[] = {}
    for var i: int = 0; i < nBatches; i++ =>
      batchOrder.push(i.toDouble())

    var perm: double[] = {}
    for var i: int = 0; i < totalSamples; i++ =>
      perm.push(i.toDouble())
    var permTarget: int = nBatches * batchSize
    var cyc: int = 0
    while len(perm) < permTarget =>
      perm.push((cyc % totalSamples).toDouble())
      cyc = cyc + 1

    var lossCurve: double[] = {}
    var gradNormCurve: double[] = {}
    var lrCurve: double[] = {}
    # Phase 2: per-epoch drift-check outputs + early-stop bookkeeping.
    var klCurve: double[] = {}
    var stoppedEarly: bool = false
    var epochsCompleted: int = 0
    # Phase 4: value-loss curve, populated only when the model has a
    # value head enabled. Each entry is the mean squared error over
    # the full training set between current V_θ(s) and the
    # value targets (advantages + V_old captured pre-training).
    var valueLossCurve: double[] = {}
    var clipFracCurve: double[] = {}

    # Capture the base LR before the epoch loop so the schedule can
    # compute effectiveLr(baseLr, epoch, totalEpochs) from a fixed
    # anchor. Mutating optParams.learningRate per epoch below does
    # NOT re-baseline because we compute from `baseLr`, not from
    # `optParams.learningRate`.
    var baseLr: double = optParams.learningRate

    using rng = Random.createWithSeed(self.config.seed) =>
      for var epoch: int = 0; epoch < epochs; epoch++ =>
        rng.shuffleDouble(batchOrder)
        for var b: int = 0; b < nBatches; b++ =>
          var srcBatch: int = batchOrder[b].toInt()
          for var k: int = 0; k < batchSize; k++ =>
            var srcIdx: int = srcBatch * batchSize + k
            if srcIdx >= totalSamples =>
              srcIdx = srcIdx % totalSamples
            perm[b * batchSize + k] = srcIdx.toDouble()

        # Phase 1.3: compute the scheduled effective LR for this epoch
        # and mutate the OptimizerParams value struct in place before
        # building the ctx. The struct is copied into ctx by value, so
        # each strategy.runEpoch call sees the right LR. For the
        # default `LrSchedule.constant()` this is a no-op passthrough
        # of baseLr — existing tests see identical behaviour.
        var effLr: double = self.config.lrSchedule.effectiveLr(baseLr, epoch, epochs)
        optParams.learningRate = effLr
        lrCurve.push(effLr)

        # Bundle up the per-epoch context and hand it to the strategy's
        # dispatcher. WeightedCrossEntropy calls sn_graph_train_epoch;
        # PpoClipped calls sn_graph_train_epoch_ppo with its extras.
        var ctx: EpochContext = {
          loss: loss,
          features: nodeFeaturesInput,
          labels: labelsInput,
          weights: weightsInput,
          featuresHost: featuresHost,
          targetsHost: targets,
          weightsHost: effectiveWeights,
          adjHost: adjHost,
          realNodeCountHost: realNodeCountHost,
          perm: perm,
          featureDim: featureDim,
          labelsPerSample: numClasses,
          batchSize: batchSize,
          maxNodes: maxNodes,
          optimizer: optParams
        }
        var epochLoss: double = self.strategy.runEpoch(ctx)
        lossCurve.push(epochLoss)

        var epochLabels: StringField[] = {
          StringField {
            key: "epoch",
            value: $"{epoch}"
          }
        }
        MetricEmitter.emit("train_loss", epochLoss, epochLabels)

        # Phase C: per-epoch param-delta L2 norm.
        var deltaSqEpoch: double = 0.0
        for var i: int = 0; i < nParams; i++ =>
          var curr: double[] = params[i].toDoubles()
          for var j: int = 0; j < len(curr); j++ =>
            var dd: double = curr[j] - rollingData[i][j]
            deltaSqEpoch = deltaSqEpoch + dd * dd
          rollingData[i] = curr
        var gradThisEpoch: double = sqrt(deltaSqEpoch)
        gradNormCurve.push(gradThisEpoch)

        MetricEmitter.emit("grad_norm_l2", gradThisEpoch, epochLabels)

        # Phase 4: post-hoc value-loss computation. Skipped entirely
        # when the model has no value head so existing tests pay zero
        # cost. When enabled, this runs one forward pass per training
        # sample in inference mode (same pattern as the Phase 2
        # target-KL drift check just below — pause/checkpoint the
        # record session, read valueEstimate, restore). The value
        # target for sample i is the raw (pre-advantage-norm) weight
        # plus the V_old captured before training started, i.e.
        # valueTargetsHost[i] in strategy state. We recompute it here
        # from the trainer's own `weights` + `initialValuesFlat`
        # arrays so the trainer doesn't have to poke into the
        # strategy's private fields.
        if self.model.valueHeadEnabled =>
          var prevRecVh: bool = sn_graph_pause_recording()
          var vSqSum: double = 0.0
          for var i: int = 0; i < totalSamples; i++ =>
            var cpVh: long = sn_tensor_pool_checkpoint()
            var vEst: double[] = self.model.forward(graphs[i], false).valueEstimate.toDoubles()
            var vPred: double = 0.0
            if len(vEst) > 0 =>
              vPred = vEst[0]
            var vTarget: double = weights[i] + initialValuesFlat[i]
            var dd: double = vPred - vTarget
            vSqSum = vSqSum + dd * dd
            sn_tensor_pool_restore(cpVh)
          sn_graph_resume_recording(prevRecVh)
          var vMse: double = vSqSum / totalSamples.toDouble()
          valueLossCurve.push(vMse)
          MetricEmitter.emit("value_loss", vMse, epochLabels)

        epochsCompleted = epochsCompleted + 1

        # Per-epoch diagnostics: KL divergence and clip fraction.
        # Both require a forward pass over every training sample to
        # get the current policy's predictions. The forward pass is
        # amortized — run once, used for both metrics. Gated on
        # either targetKl > 0 or clipEpsilon > 0.
        var needDiagForward: bool = self.config.targetKl > 0.0 || self.config.clipEpsilon > 0.0
        if needDiagForward =>
          var prevRec: bool = sn_graph_pause_recording()

          var currentProbsFlat: double[] = {}
          for var i: int = 0; i < totalSamples; i++ =>
            var cp: long = sn_tensor_pool_checkpoint()
            var probs: double[] = self.model.forward(graphs[i], false).probs.toDoubles()
            for var j: int = 0; j < len(probs); j++ =>
              currentProbsFlat.push(probs[j])
            sn_tensor_pool_restore(cp)

          sn_graph_resume_recording(prevRec)

          # KL divergence: mean per-sample KL(current || initial).
          if self.config.targetKl > 0.0 =>
            var klSum: double = 0.0
            for var i: int = 0; i < totalSamples; i++ =>
              var a: double[] = {}
              var b: double[] = {}
              for var j: int = 0; j < numClasses; j++ =>
                a.push(currentProbsFlat[i * numClasses + j])
                b.push(initialProbsFlat[i * numClasses + j])
              klSum = klSum + distributionDivergence(a, b, "kl")
            var klMean: double = klSum / totalSamples.toDouble()
            klCurve.push(klMean)
            MetricEmitter.emit("kl_divergence", klMean, epochLabels)

            if klMean > self.config.targetKl =>
              stoppedEarly = true

          # Clip fraction: for each sample, compute the policy ratio
          # for the taken action and count how many fall outside
          # [1-epsilon, 1+epsilon].
          if self.config.clipEpsilon > 0.0 =>
            var clipCount: int = 0
            var epsClip: double = self.config.clipEpsilon
            for var i: int = 0; i < totalSamples; i++ =>
              # Find the taken action from the one-hot targets.
              var takenIdx: int = 0
              for var j: int = 0; j < numClasses; j++ =>
                if targets[i * numClasses + j] > 0.5 =>
                  takenIdx = j
              var piNew: double = currentProbsFlat[i * numClasses + takenIdx]
              var piOld: double = initialProbsFlat[i * numClasses + takenIdx]
              if piOld < 0.000000001 =>
                piOld = 0.000000001
              var ratio: double = piNew / piOld
              if ratio < 1.0 - epsClip || ratio > 1.0 + epsClip =>
                clipCount = clipCount + 1
            var clipFrac: double = clipCount.toDouble() / totalSamples.toDouble()
            clipFracCurve.push(clipFrac)
            MetricEmitter.emit("clip_fraction", clipFrac, epochLabels)

          if stoppedEarly =>
            break

    # Optimizer state: save m/v moments before the session tears down
    # g_opt_ctx. Must happen while the opt context is still alive.
    if self.config.optStateSavePath != "" =>
      sn_opt_state_save(self.config.optStateSavePath + ".opt")

    session.dispose()

    # Phase 1.4: release the native clip threshold so subsequent
    # trainer runs start from the disabled state unless they opt in
    # again via TrainConfig.gradClipNorm.
    sn_graph_set_grad_clip_norm(0.0)

    # --- Phase C: post-train per-parameter snapshots. ----------------------
    var paramNormAfter: double[] = {}
    var paramMaxAbsDelta: double[] = {}
    for var i: int = 0; i < nParams; i++ =>
      paramNormAfter.push(params[i].norm())
      var curr: double[] = params[i].toDoubles()
      var m: double = 0.0
      for var j: int = 0; j < len(curr); j++ =>
        var dd: double = curr[j] - initialData[i][j]
        if dd < 0.0 =>
          dd = -dd
        if dd > m =>
          m = dd
      paramMaxAbsDelta.push(m)

    # --- Phase C: training-set accuracy after the final epoch. -------------
    var correct: int = 0
    for var i: int = 0; i < totalSamples; i++ =>
      var probs: double[] = self.model.forward(graphs[i], false).probs.toDoubles()
      var predIdx: int = 0
      for var j: int = 1; j < numClasses; j++ =>
        if probs[j] > probs[predIdx] =>
          predIdx = j
      var trueIdx: int = 0
      for var j: int = 1; j < numClasses; j++ =>
        if targets[i * numClasses + j] > targets[i * numClasses + trueIdx] =>
          trueIdx = j
      if predIdx == trueIdx =>
        correct = correct + 1
    var accuracy: double = correct.toDouble() / totalSamples.toDouble()

    var finalLoss: double = lossCurve[len(lossCurve) - 1]

    # --- Phase M: post-train scalar and per-parameter metric emissions. ---
    var noLabels: StringField[] = {}
    MetricEmitter.emit("weight_sum_in", weightSumIn, noLabels)
    MetricEmitter.emit("weight_variance_in", weightVarianceIn, noLabels)
    MetricEmitter.emit("input_mean", inputMean, noLabels)
    MetricEmitter.emit("input_std", inputStd, noLabels)
    MetricEmitter.emit("accuracy", accuracy, noLabels)

    var paramsPerLayer: int = 2
    if self.model.config.arch == "gat" =>
      paramsPerLayer = 4
    var layerParamsTotal: int = len(self.model.layers) * paramsPerLayer
    for var i: int = 0; i < nParams; i++ =>
      var plabels: StringField[] = {}
      if i < layerParamsTotal =>
        var layerIdx: int = i / paramsPerLayer
        var kindIdx: int = i % paramsPerLayer
        var kindName: str = "weight"
        if kindIdx == 1 =>
          kindName = "bias"
        if kindIdx == 2 =>
          kindName = "attSrc"
        if kindIdx == 3 =>
          kindName = "attDst"
        plabels = {
          StringField {
            key: "layer",
            value: $"{layerIdx}"
          },
          StringField {
            key: "kind",
            value: kindName
          }
        }
      else =>
        var clsIdx: int = i - layerParamsTotal
        var clsName: str = "classW1"
        if clsIdx == 1 =>
          clsName = "classB1"
        if clsIdx == 2 =>
          clsName = "classW2"
        if clsIdx == 3 =>
          clsName = "classB2"
        plabels = {
          StringField {
            key: "kind",
            value: clsName
          }
        }
      MetricEmitter.emit("param_norm_before", paramNormBefore[i], plabels)
      MetricEmitter.emit("param_norm_after", paramNormAfter[i], plabels)
      MetricEmitter.emit("param_max_abs_delta", paramMaxAbsDelta[i], plabels)

    return TrainResult {
      loss: finalLoss,
      accuracy: accuracy,
      epochs: epochsCompleted,
      lossCurve: lossCurve,
      gradNormCurve: gradNormCurve,
      paramNormBefore: paramNormBefore,
      paramNormAfter: paramNormAfter,
      paramMaxAbsDelta: paramMaxAbsDelta,
      weightSumIn: weightSumIn,
      weightVarianceIn: weightVarianceIn,
      inputMean: inputMean,
      inputStd: inputStd,
      lrCurve: lrCurve,
      klCurve: klCurve,
      stoppedEarly: stoppedEarly,
      valueLossCurve: valueLossCurve,
      clipFracCurve: clipFracCurve
    }
